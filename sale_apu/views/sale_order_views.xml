<odoo>
    <record id="view_sale_order_form_inherit_apu" model="ir.ui.view">
        <field name="name">sale.order.form.apu</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="APU" groups="sale_apu.group_apu_view_costs,sales_team.group_sale_manager">
                    <group>
                        <field name="apu_line_ids" mode="list,form" nolabel="1">
                            <list editable="bottom" default_order="sequence, id">
                                <control>
                                    <create name="add_apu_product_control" string="Add a product"/>
                                    <create name="add_apu_section_control" string="Add a section" context="{'default_display_type': 'line_section'}"/>
                                    <create name="add_apu_note_control" string="Add a note" context="{'default_display_type': 'line_note'}"/>
                                    <button name="action_add_from_catalog" string="Catalog" type="object" class="btn-secondary" context="{'order_id': parent.id}"/>
                                </control>
                                <field name="sequence" widget="handle" readonly="source_order_line_id"/>
                                <field name="source_order_line_id" column_invisible="True"/>
                                <field name="display_type" column_invisible="True"/>
                                <field name="product_id" options="{'no_create_edit': True}" required="not display_type" invisible="display_type" readonly="source_order_line_id"/>
                                <field name="name" widget="sol_text" readonly="source_order_line_id"/>
                                <field name="quantity" invisible="display_type" readonly="source_order_line_id"/>
                                <field name="product_uom_id" required="not display_type" invisible="display_type" readonly="source_order_line_id"/>
                                <field name="unit_cost" groups="sale_apu.group_apu_view_costs,sales_team.group_sale_manager" invisible="display_type"/>
                                <field name="subtotal" sum="Cost Subtotal" groups="sale_apu.group_apu_view_costs,sales_team.group_sale_manager" invisible="display_type"/>
                            </list>
                            <form string="APU Line">
                                <sheet>
                                    <group>
                                        <group>
                                            <field name="display_type" invisible="1"/>
                                            <field name="source_order_line_id" invisible="1"/>
                                            <field name="product_id" options="{'no_create_edit': True}" required="not display_type" invisible="display_type" readonly="source_order_line_id"/>
                                            <field name="name" readonly="source_order_line_id"/>
                                            <field name="quantity" invisible="display_type" readonly="source_order_line_id"/>
                                        </group>
                                        <group>
                                            <field name="product_uom_id" required="not display_type" invisible="display_type" readonly="source_order_line_id"/>
                                            <field name="unit_cost" groups="sale_apu.group_apu_view_costs,sales_team.group_sale_manager" invisible="display_type"/>
                                            <field name="subtotal" readonly="1" groups="sale_apu.group_apu_view_costs,sales_team.group_sale_manager" invisible="display_type"/>
                                        </group>
                                    </group>
                                </sheet>
                            </form>
                        </field>
                    </group>
                    <group col="4">
                        <field name="apu_total" readonly="1" groups="sale_apu.group_apu_view_costs,sales_team.group_sale_manager"/>
                        <field name="apu_expected_profit" readonly="1" groups="sale_apu.group_apu_view_costs,sales_team.group_sale_manager"/>
                        <field name="apu_margin_percent" readonly="1" groups="sale_apu.group_apu_view_costs,sales_team.group_sale_manager"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
