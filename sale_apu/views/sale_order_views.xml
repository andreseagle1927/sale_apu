<odoo>
    <record id="view_sale_order_form_inherit_apu" model="ir.ui.view">
        <field name="name">sale.order.form.apu</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="APU" groups="sale_apu.group_apu_view_costs,sale.group_sale_manager">
                    <group>
                        <field name="apu_line_ids" mode="list,form" nolabel="1">
                            <list editable="bottom" default_order="sequence, id">
                                <field name="sequence" widget="handle"/>
                                <field name="product_id" options="{'no_create_edit': True}"/>
                                <field name="name"/>
                                <field name="quantity"/>
                                <field name="product_uom_id"/>
                                <field name="unit_cost" groups="sale_apu.group_apu_view_costs,sale.group_sale_manager"/>
                                <field name="subtotal" sum="Cost Subtotal" groups="sale_apu.group_apu_view_costs,sale.group_sale_manager"/>
                            </list>
                            <form string="APU Line">
                                <sheet>
                                    <group>
                                        <group>
                                            <field name="product_id" options="{'no_create_edit': True}"/>
                                            <field name="name"/>
                                            <field name="quantity"/>
                                        </group>
                                        <group>
                                            <field name="product_uom_id"/>
                                            <field name="unit_cost" groups="sale_apu.group_apu_view_costs,sale.group_sale_manager"/>
                                            <field name="subtotal" readonly="1" groups="sale_apu.group_apu_view_costs,sale.group_sale_manager"/>
                                        </group>
                                    </group>
                                </sheet>
                            </form>
                        </field>
                    </group>
                    <group col="4">
                        <field name="apu_total" readonly="1" groups="sale_apu.group_apu_view_costs,sale.group_sale_manager"/>
                        <field name="apu_expected_profit" readonly="1" groups="sale_apu.group_apu_view_costs,sale.group_sale_manager"/>
                        <field name="apu_margin_percent" readonly="1" groups="sale_apu.group_apu_view_costs,sale.group_sale_manager"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
